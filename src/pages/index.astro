---
import Layout from '../layouts/Layout.astro';
import FAQAccordion from '../components/FAQAccordion.jsx';
import CookieBanner from '../components/CookieBanner.jsx';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "BrightMind AI Solutions",
    "legalName": "BrightMind AI Solutions",
    "alternateName": "BrightMind AI",
    "url": "https://brightmindsolutions.pl/",
    "logo": "https://brightmindsolutions.pl/logo.png",
    "image": "https://brightmindsolutions.pl/og-image.jpg",
    "description": "BrightMind AI Solutions to polska firma specjalizująca się we wdrożeniach AI B2B — automatyzacja procesów AI, agenci AI dla firm i wdrożenia AI dla przedsiębiorstw. Doradztwo AI, korepetycje i materiały marketingowe AI.",
    "foundingDate": "2024",
    "areaServed": "PL",
    "knowsAbout": ["automatyzacja procesów AI", "agenci AI dla firm", "wdrożenia AI B2B", "automatyzacja marketingu AI", "LangChain", "n8n", "Zapier", "ChatGPT dla firm", "Claude AI", "lokalne modele LLM"],
    "serviceType": ["Automatyzacja Procesów AI", "Agenci AI dla Firm", "Wdrożenia AI B2B", "Automatyzacja Marketingu AI", "Doradztwo AI dla Firm", "Korepetycje AI", "Tworzenie Stron i Aplikacji AI", "Wdrożenia AI i Compliance NIS2"],
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "telephone": "+48-730-152-161",
      "email": "kontakt@brightmind-solutions.com",
      "availableLanguage": ["Polish", "English"],
      "areaServed": "PL"
    },
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "PL",
      "addressRegion": "Polska"
    },
    "founder": {
      "@type": "Person",
      "name": "Patryk Gliński",
      "url": "https://brightmindsolutions.pl/o-mnie/",
      "sameAs": ["https://www.linkedin.com/in/patryk-gli%C5%84ski-172370215"]
    },
    "sameAs": [
      "https://www.youtube.com/@Neural_Update",
      "https://www.linkedin.com/company/brightmind-ai-solutions"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "BrightMind AI Solutions",
    "url": "https://brightmindsolutions.pl/",
    "description": "Profesjonalne wdrożenia AI B2B — automatyzacja procesów AI, agenci AI dla firm, doradztwo AI i korepetycje.",
    "inLanguage": "pl-PL",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://brightmindsolutions.pl/?q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Wdrożenia AI dla Biznesu",
    "description": "Kompleksowe usługi wdrażania sztucznej inteligencji w przedsiębiorstwach",
    "provider": { "@type": "Organization", "name": "BrightMind AI Solutions" },
    "areaServed": "Poland",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Usługi AI",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Doradztwo AI dla Firm" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Korepetycje AI" }, "price": "61.5", "priceCurrency": "PLN" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pakiet Start-AI" }, "price": "369", "priceCurrency": "PLN" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Automatyzacja i Agenci AI" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tworzenie Stron i Aplikacji AI" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Wdrożenia AI i Compliance NIS2", "url": "https://brightmindsolutions.pl/NIS2/" } }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Czy AI zastąpi moich pracowników?", "acceptedAnswer": { "@type": "Answer", "text": "Nie - AI ma za zadanie wspierać i wzmacniać możliwości pracowników, a nie ich zastępować. Automatyzacja procesów AI eliminuje rutynowe zadania, dzięki czemu zespół skupia się na kreatywnych i strategicznych działaniach. BrightMind AI Solutions wdraża agentów AI dla firm w modelu B2B, który uzupełnia - nie zastępuje - istniejące zasoby ludzkie." } },
      { "@type": "Question", "name": "Ile kosztuje wdrożenie AI w firmie?", "acceptedAnswer": { "@type": "Answer", "text": "Koszty wdrożenia AI B2B zależą od skali i złożoności projektu. Pakiet Start-AI (diagnoza potrzeb) kosztuje 369 zł, a kompleksowe wdrożenia AI dla firm rozpoczynamy od 2000 zł. Korepetycje AI to 61,5 zł/h. Oferujemy bezpłatną konsultację." } },
      { "@type": "Question", "name": "Jak długo trwa wdrożenie AI dla firmy?", "acceptedAnswer": { "@type": "Answer", "text": "Podstawowe wdrożenie automatyzacji procesów AI zajmuje 1-2 tygodnie, a kompleksowe projekty wdrożeń AI B2B 1-3 miesiące. Pierwsze efekty widoczne są już po 7 dniach." } },
      { "@type": "Question", "name": "Czy dane firmy są bezpieczne podczas wdrożeń AI?", "acceptedAnswer": { "@type": "Answer", "text": "Tak. BrightMind AI Solutions oferuje wdrożenia AI zgodne z RODO. Korzystamy z lokalnych modeli LLM lub bezpiecznych API. Dane nigdy nie są używane do trenowania modeli AI." } },
      { "@type": "Question", "name": "Jakie usługi AI B2B oferuje BrightMind AI Solutions?", "acceptedAnswer": { "@type": "Answer", "text": "BrightMind AI Solutions oferuje: automatyzację procesów AI (n8n, Zapier, LangChain), agentów AI dla firm, wdrożenia AI B2B, doradztwo AI dla firm, korepetycje AI, automatyzację marketingu AI, spersonalizowane asystenty AI oraz tworzenie stron i aplikacji AI." } },
      { "@type": "Question", "name": "Czy BrightMind AI Solutions pomaga w spełnieniu wymogów NIS2?", "acceptedAnswer": { "@type": "Answer", "text": "Tak. BrightMind AI Solutions oferuje kompleksowe wsparcie we wdrażaniu rozwiązań AI zgodnych z dyrektywą NIS2. Obejmuje to audyt bezpieczeństwa systemów AI, implementację procedur cyberbezpieczeństwa, zarządzanie ryzykiem i raportowanie incydentów. Patryk Gliński łączy wiedzę prawniczą z certyfikatem Blue Team z HackerU, co pozwala na kompleksowe podejście do compliance AI." } },
      { "@type": "Question", "name": "Jakie narzędzia AI używa BrightMind AI Solutions do automatyzacji?", "acceptedAnswer": { "@type": "Answer", "text": "BrightMind AI Solutions specjalizuje się w automatyzacji z wykorzystaniem: n8n (platformy no-code/low-code), Zapier (integracje SaaS), LangChain (agenci AI), ChatGPT API, Claude AI (Anthropic), GitHub Copilot, lokalnych modeli LLM oraz Sanity.io CMS. Dobór narzędzi zależy od potrzeb konkretnego klienta." } },
      { "@type": "Question", "name": "Czy BrightMind AI Solutions oferuje bezpłatną konsultację?", "acceptedAnswer": { "@type": "Answer", "text": "Tak. BrightMind AI Solutions oferuje bezpłatną konsultację wstępną, podczas której omawiamy potrzeby firmy i potencjał automatyzacji AI. Skontaktuj się pod adresem kontakt@brightmind-solutions.com lub telefonicznie +48 730 152 161." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "Jak wdrożyć AI w firmie krok po kroku",
    "description": "Praktyczny przewodnik po procesie wdrożenia sztucznej inteligencji w przedsiębiorstwie — od diagnozy potrzeb po uruchomienie produkcyjne.",
    "totalTime": "P14D",
    "estimatedCost": { "@type": "MonetaryAmount", "currency": "PLN", "value": "369" },
    "supply": [{ "@type": "HowToSupply", "name": "Dostęp do procesów biznesowych firmy" }, { "@type": "HowToSupply", "name": "Dane lub dokumenty do automatyzacji" }],
    "tool": [{ "@type": "HowToTool", "name": "n8n lub Zapier" }, { "@type": "HowToTool", "name": "ChatGPT API lub Claude AI" }, { "@type": "HowToTool", "name": "LangChain (dla agentów AI)" }],
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Diagnoza potrzeb — Pakiet Start-AI", "text": "Przeprowadzamy kompleksową diagnozę procesów biznesowych firmy. Identyfikujemy obszary o największym potencjale automatyzacji AI, tworzymy mapę procesów i roadmapę wdrożenia. Etap kończy się minibook z rekomendacjami (koszt: 369 zł).", "url": "https://brightmindsolutions.pl/#pakiety" },
      { "@type": "HowToStep", "position": 2, "name": "Wybór narzędzi i technologii", "text": "Na podstawie diagnozy dobieramy odpowiednie narzędzia AI: n8n/Zapier do integracji, LangChain do agentów, modele LLM (ChatGPT, Claude, lokalne modele). Dla danych wrażliwych rekomendujemy lokalne modele LLM bez wychodzenia danych poza infrastrukturę klienta.", "url": "https://brightmindsolutions.pl/#uslugi" },
      { "@type": "HowToStep", "position": 3, "name": "Konfiguracja i wdrożenie pilotażowe", "text": "Wdrażamy pilot automatyzacji w wybranym procesie. Konfigurujemy przepływy pracy (workflows), agentów AI i integracje z istniejącymi systemami. Pierwsze efekty widoczne po 7 dniach.", "url": "https://brightmindsolutions.pl/#uslugi" },
      { "@type": "HowToStep", "position": 4, "name": "Szkolenie zespołu i przekazanie", "text": "Szkolimy pracowników z obsługi wdrożonych narzędzi AI. Przekazujemy dokumentację, playbook bezpieczeństwa i bibliotekę promptów. Zapewniamy wsparcie poimplementacyjne.", "url": "https://brightmindsolutions.pl/#kontakt" },
      { "@type": "HowToStep", "position": 5, "name": "Optymalizacja i skalowanie", "text": "Monitorujemy efekty wdrożenia, optymalizujemy przepływy i rozszerzamy automatyzację na kolejne obszary. Kompleksowe wdrożenia AI B2B trwają od 1 do 3 miesięcy.", "url": "https://brightmindsolutions.pl/#kontakt" }
    ]
  }
];
---

<Layout
  title="BrightMind AI Solutions — Wdrożenia AI B2B | Automatyzacja Procesów AI i Agenci AI dla Firm"
  description="Profesjonalne wdrożenia AI B2B dla firm. Automatyzacja procesów AI, agenci AI dla firm, doradztwo i korepetycje AI. Transformuj swój biznes — pierwsze efekty po 7 dniach!"
  canonical="https://brightmindsolutions.pl/"
  keywords="wdrożenia AI B2B, automatyzacja procesów AI, agenci AI dla firm, doradztwo AI Polska, compliance NIS2, korepetycje AI"
  ogTitle="BrightMind AI Solutions — Wdrożenia AI B2B i Agenci AI dla Firm"
  ogDescription="Profesjonalne wdrożenia AI B2B, automatyzacja procesów, agenci AI i compliance NIS2. Pierwsze efekty po 7 dniach. Bezpłatna konsultacja."
  ldJson={ldJson}
  fbPixelId="857800850017857"
  hreflang={{ pl: "https://brightmindsolutions.pl/", en: "https://brightmindsolutions.pl/en/", xDefault: "https://brightmindsolutions.pl/" }}
>
  <!-- Netlify Forms detection -->
  <form name="contact" netlify netlify-honeypot="bot-field" hidden>
    <input name="bot-field" />
    <input name="name" />
    <input name="email" type="email" />
    <input name="phone" type="tel" />
    <input name="company" />
    <select name="subject"></select>
    <textarea name="message"></textarea>
    <input type="checkbox" name="privacy_consent" />
    <input type="checkbox" name="marketing_consent" />
  </form>

  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-brand">
        <span class="nav-brand-mark">B</span>
        <span>BrightMind <span style="color:var(--fg-muted)">/ AI</span></span>
      </a>
      <div class="nav-links">
        <a href="/" class="active">Strona Główna</a>
        <a href="/o-mnie/">O mnie</a>
        <a href="#uslugi">Usługi</a>
        <a href="/NIS2/">NIS2</a>
        <a href="/ai-w-praktyce/">AI w Praktyce</a>
        <a href="/portfolio/">Portfolio</a>
        <a href="#kontakt">Kontakt</a>
        <a href="/en/" class="lang-switch" aria-label="English version" style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border:1px solid var(--border);border-radius:var(--radius);font-size:0.8rem;color:var(--fg-muted);text-decoration:none">
          <span style="color:var(--accent)">PL</span>
          <span style="opacity:0.4">/</span>
          <span style="font-weight:600;color:var(--fg-muted)">EN</span>
        </a>
        <a href="#kontakt" class="nav-cta">Bezpłatna konsultacja →</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section style="padding:100px 0 80px;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;opacity:0.45;pointer-events:none;background-image:radial-gradient(ellipse 80% 60% at 70% 20%,var(--accent-soft),transparent 60%)"></div>
    <div class="container" style="position:relative">
      <div style="display:grid;grid-template-columns:1.05fr 0.95fr;gap:72px;align-items:center">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">● BrightMind AI Solutions</div>
          <h1 style="margin-bottom:16px;font-size:clamp(2.5rem,4.6vw,4rem);line-height:1.05">
            Doradztwo AI i Wdrożenia AI B2B
          </h1>
          <p style="font-size:1.4rem;color:var(--fg);margin-bottom:24px;font-weight:400;opacity:0.9">
            Automatyzacja procesów i <span class="accent">Agenci AI dla Firm</span>
          </p>
          <p style="font-size:1.15rem;color:var(--fg-muted);margin-bottom:36px;max-width:540px">
            AI w praktyce — rozwiązania, które naprawdę ułatwiają codzienną pracę. Patryk Gliński — radca prawny, Google Cloud Generative AI Leader, Blue Team HackerU.
          </p>
          <div style="display:flex;gap:12px;flex-wrap:wrap">
            <a href="#uslugi" class="btn btn-primary">Rozpocznij transformację AI
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
            </a>
            <a href="#kontakt" class="btn btn-secondary">Bezpłatna konsultacja</a>
          </div>
        </div>
        <div class="card" style="padding:0;overflow:hidden;border-color:var(--border-strong);box-shadow:0 30px 80px -30px rgba(0,0,0,0.45)">
          <div style="background:var(--bg-elev-2);padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px">
            <span style="width:10px;height:10px;border-radius:50%;background:#f87171"></span>
            <span style="width:10px;height:10px;border-radius:50%;background:#fbbf24"></span>
            <span style="width:10px;height:10px;border-radius:50%;background:#34d399"></span>
            <span class="mono" style="font-size:0.75rem;color:var(--fg-muted);margin-left:8px">brightmind ~ uslugi</span>
            <span class="mono" style="font-size:0.7rem;color:var(--success);margin-left:auto">● online</span>
          </div>
          <div style="padding:24px;font-family:var(--font-mono);font-size:0.875rem;line-height:1.85">
            <div class="text-muted"># Usługi</div>
            <div style="margin-top:10px;display:flex;flex-direction:column;gap:4px">
              <div><span class="accent">→</span> Doradztwo AI dla Firm</div>
              <div><span class="accent">→</span> Korepetycje AI</div>
              <div><span class="accent">→</span> Automatyzacja Marketingu AI</div>
              <div><span class="accent">→</span> Automatyzacja i Agenci AI dla Firm</div>
              <div><span class="accent">→</span> Spersonalizowane Asystenty AI</div>
              <div><span class="accent">→</span> Wdrożenia AI i Compliance NIS2</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section" id="uslugi">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">/ Usługi</span>
        <h2>Nasze Usługi</h2>
      </div>
      <div class="grid grid-3">
        <div class="card">
          <div style="color:var(--accent);margin-bottom:16px">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M5 7h14"/><path d="M5 7l-3 7a4 4 0 008 0L7 7"/><path d="M19 7l-3 7a4 4 0 008 0L21 7"/></svg>
          </div>
          <h3 style="margin-bottom:12px">Doradztwo AI dla Firm</h3>
          <p class="text-muted" style="font-size:0.95rem">Profesjonalne doradztwo w zakresie wdrażania AI: od narzędzi do programowania (GitHub Copilot, Claude Code), przez tworzenie audio, wideo i prezentacji, transkrypcje spotkań, aż po zastosowania w prawie, medycynie i rolnictwie. Identyfikuję obszary o największym potencjale automatyzacji w Twojej branży.</p>
        </div>
        <div class="card">
          <div style="color:var(--accent);margin-bottom:16px">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
          </div>
          <h3 style="margin-bottom:12px">Korepetycje AI</h3>
          <p class="text-muted" style="font-size:0.95rem">Indywidualne szkolenia z zakresu sztucznej inteligencji dla osób prywatnych. Asystenci programistyczni, generatory audio i wideo, aplikacje do transkrypcji, branżowe rozwiązania AI. Niezależnie od dziedziny — pomogę wykorzystać potencjał AI.</p>
        </div>
        <div class="card">
          <div style="color:var(--accent);margin-bottom:16px">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>
          </div>
          <h3 style="margin-bottom:12px">Automatyzacja Marketingu AI</h3>
          <p class="text-muted" style="font-size:0.95rem">Kompleksowa automatyzacja marketingu z wykorzystaniem AI. Treści reklamowe, posty społecznościowe, kampanie e-mailowe i grafiki generowane przez AI — bez ręcznej pracy.</p>
        </div>
        <div class="card">
          <div style="color:var(--accent);margin-bottom:16px">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3"/></svg>
          </div>
          <h3 style="margin-bottom:12px">Automatyzacja i Agenci AI dla Firm</h3>
          <p class="text-muted" style="font-size:0.95rem">Inteligentni agenci i zaawansowane przepływy automatyzacji z wykorzystaniem n8n, Zapier i LangChain. Automatyzuję powtarzalne procesy, integruję systemy i tworzę autonomicznych agentów AI wykonujących złożone zadania bez Twojego udziału.</p>
        </div>
        <div class="card">
          <div style="color:var(--accent);margin-bottom:16px">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="12" rx="2"/><path d="M12 8V4M8 4h8"/><circle cx="9" cy="14" r="1"/><circle cx="15" cy="14" r="1"/></svg>
          </div>
          <h3 style="margin-bottom:12px">Spersonalizowane Asystenty AI</h3>
          <p class="text-muted" style="font-size:0.95rem">Projektowanie i wdrażanie dedykowanych asystentów AI dopasowanych do specyfiki branży. Od automatyzacji obsługi klienta, przez analizę dokumentów prawnych i medycznych, po wsparcie w rolnictwie precyzyjnym. Pełna integracja z istniejącymi systemami.</p>
        </div>
        <div class="card card-accent">
          <span class="chip" style="margin-bottom:16px;color:var(--accent);border-color:var(--accent)">★ Flagship</span>
          <div style="color:var(--accent);margin-bottom:16px">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <h3 style="margin-bottom:12px">Wdrożenia AI i Compliance NIS2</h3>
          <p class="text-muted" style="font-size:0.95rem">Kompleksowe wsparcie we wdrażaniu rozwiązań AI zgodnych z dyrektywą NIS2. Audyt bezpieczeństwa, procedury cyberbezpieczeństwa, zarządzanie ryzykiem i raportowanie incydentów. Spełnij wymogi regulacyjne wykorzystując potencjał AI.</p>
          <a href="/NIS2/" style="display:inline-flex;align-items:center;gap:6px;margin-top:16px;font-size:0.875rem;font-weight:500">
            Zobacz dedykowaną stronę
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PACKAGES -->
  <section class="section" id="pakiety" style="background:var(--bg-elev)">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">/ Pakiety</span>
        <h2>Nasze Pakiety</h2>
      </div>
